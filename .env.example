# ─────────────────────────────────────────────────────────────────────────────
# Datenmonster – Konfigurationsvorlage
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── Ports ────────────────────────────────────────────────────────────────────
FRONTEND_PORT=5174
BACKEND_PORT=8000

# ─── Sicherheit ───────────────────────────────────────────────────────────────
# Zufälligen langen String generieren: openssl rand -hex 32
SECRET_KEY=dein-geheimer-schluessel-hier-ersetzen
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Lizenz ───────────────────────────────────────────────────────────────────
# Fester Hostname für die Lizenzbindung (machine_id). MUSS pro Installation stabil
# bleiben – sonst bricht die Aktivierung bei jedem Container-Update. Pro Kunde ggf.
# eindeutig setzen, z. B. datenmonster-kundexy.
LICENSE_HOSTNAME=datenmonster

# ─── Admin-Account ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dein-admin-passwort-hier-ersetzen

# ─── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////data/datenmonster.db

# ─── Upload-Verzeichnis ───────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
