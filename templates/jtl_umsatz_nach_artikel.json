{
  "template_id": "jtl_umsatz_nach_artikel",
  "template_name": "JTL – Umsatz nach Artikel",
  "description": "Dashboard-Formular: Top-Artikel, verkaufte Menge und Umsatzanteile aus der JTL-Wawi.",
  "category": "jtl-reporting",
  "version": "2.0",
  "author": "Datenmonster",
  "hinweise": [
    "Beim Installieren die JTL-Datenbankverbindung (MS SQL) auswählen – Zugangsdaten werden nicht mitgeliefert.",
    "Formular öffnen und die Auswerten-Buttons klicken, damit die Widgets Daten laden.",
    "Aggregation passiert im SQL (GROUP BY) – die Widgets zeigen fertige Summen.",
    "SQL nutzt Rechnung.vRechnung + Rechnung.tRechnungPosition."
  ],
  "config_required": [
    {
      "key": "connection_jtl",
      "label": "JTL-Datenbankverbindung (MS SQL Server)",
      "type": "connection",
      "default": ""
    },
    {
      "key": "monate",
      "label": "Zeitraum rückwirkend in Monaten",
      "type": "text",
      "default": "24"
    }
  ],
  "datasets": [],
  "mappings": [
    {
      "id": "mapping_kpi",
      "name": "Artikel-Kennzahlen",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "SELECT\n    CAST(SUM(REPO.fAnzahl * REPO.fVkNetto) AS DECIMAL(18,2)) AS Gesamtumsatz,\n    CAST(SUM(REPO.fAnzahl) AS DECIMAL(18,2)) AS VerkaufteMenge\nFROM Rechnung.vRechnung RE\nJOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\nWHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n  AND RE.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Gesamtumsatz",
            "VerkaufteMenge"
          ]
        }
      ],
      "agg_nodes": [],
      "transform_nodes": [],
      "constant_nodes": [],
      "rest_nodes": [],
      "lookup_nodes": [],
      "calc_nodes": [],
      "switch_nodes": [],
      "sort_nodes": [],
      "targets": [
        {
          "id": "t1",
          "name": "Artikel-Kennzahlen",
          "target_type": "dataset",
          "target_connection_id": null,
          "target_table": "",
          "target_write_mode": "replace",
          "target_options": {},
          "fields": [
            {
              "source_field": "Gesamtumsatz",
              "target_field": "Gesamtumsatz",
              "target_type": "float",
              "source_dataset_id": "__sql__sql1",
              "transformer": {
                "type": "direct",
                "source_field": "Gesamtumsatz"
              }
            },
            {
              "source_field": "VerkaufteMenge",
              "target_field": "VerkaufteMenge",
              "target_type": "float",
              "source_dataset_id": "__sql__sql1",
              "transformer": {
                "type": "direct",
                "source_field": "VerkaufteMenge"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mapping_top_artikel",
      "name": "Top 15 Artikel nach Umsatz",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "SELECT TOP 15\n    REPO.cArtNr AS Artikelnummer,\n    MAX(REPO.cName) AS Artikelname,\n    CAST(SUM(REPO.fAnzahl * REPO.fVkNetto) AS DECIMAL(18,2)) AS Umsatz\nFROM Rechnung.vRechnung RE\nJOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\nWHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n  AND RE.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))\nGROUP BY REPO.cArtNr\nORDER BY Umsatz DESC",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Artikelnummer",
            "Artikelname",
            "Umsatz"
          ]
        }
      ],
      "agg_nodes": [],
      "transform_nodes": [],
      "constant_nodes": [],
      "rest_nodes": [],
      "lookup_nodes": [],
      "calc_nodes": [],
      "switch_nodes": [],
      "sort_nodes": [],
      "targets": [
        {
          "id": "t1",
          "name": "Top 15 Artikel nach Umsatz",
          "target_type": "dataset",
          "target_connection_id": null,
          "target_table": "",
          "target_write_mode": "replace",
          "target_options": {},
          "fields": [
            {
              "source_field": "Artikelnummer",
              "target_field": "Artikelnummer",
              "target_type": "string",
              "source_dataset_id": "__sql__sql1",
              "transformer": {
                "type": "direct",
                "source_field": "Artikelnummer"
              }
            },
            {
              "source_field": "Artikelname",
              "target_field": "Artikelname",
              "target_type": "string",
              "source_dataset_id": "__sql__sql1",
              "transformer": {
                "type": "direct",
                "source_field": "Artikelname"
              }
            },
            {
              "source_field": "Umsatz",
              "target_field": "Umsatz",
              "target_type": "float",
              "source_dataset_id": "__sql__sql1",
              "transformer": {
                "type": "direct",
                "source_field": "Umsatz"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mapping_tabelle",
      "name": "Artikelliste (Detail)",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "SELECT TOP 100\n    REPO.cArtNr AS Artikelnummer,\n    MAX(REPO.cName) AS Artikelname,\n    CAST(SUM(REPO.fAnzahl) AS DECIMAL(18,2)) AS Menge,\n    CAST(SUM(REPO.fAnzahl * REPO.fVkNetto) AS DECIMAL(18,2)) AS Umsatz\nFROM Rechnung.vRechnung RE\nJOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\nWHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n  AND RE.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))\nGROUP BY REPO.cArtNr\nORDER BY Umsatz DESC",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Artikelnummer",
            "Artikelname",
            "Menge",
            "Umsatz"
          ]
        }
      ],
