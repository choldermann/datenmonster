    {
      "id": "mapping_21",
      "name": "Intrastat Ausfuhr (eSTATISTIK.core)",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 111,
          "y": 28,
          "connection_id": "{{connection_10}}",
          "sql": "SELECT\n    ROW_NUMBER() OVER (ORDER BY A.cTaric, RE.cVersandlandISO, RELI.cISO, REPO.cEinheit) AS position_number,\n    A.cTaric AS commodity_code,\n    RE.cVersandlandISO AS country_of_origin,\n    RELI.cISO AS partner_country,\n    '11' AS transaction_nature,\n    '3' AS mode_of_transport,\n    CAST(ROUND(SUM(REPO.fAnzahl * A.fGewicht), 0) AS INT) AS net_mass,\n    CAST(ROUND(SUM(REPO.fAnzahl * REPO.fVkNetto), 0) AS INT) AS statistical_value,\n    CAST(ROUND(SUM(REPO.fAnzahl * REPO.fVkNetto), 0) AS INT) AS invoiced_amount,\n    REPO.cEinheit AS quantity_unit\nFROM Rechnung.vRechnung RE\nJOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\nJOIN Rechnung.vRechnungLieferadresse RELI ON RE.kRechnung = RELI.kRechnung\nJOIN dbo.tArtikel A ON A.kArtikel = REPO.kArtikel\nWHERE RELI.cISO IN ('AT','BE','BG','HR','CY','CZ','DK','EE','ES','FI','FR','GR','HU','IE','IT','LT','LU','LV','MT','NL','PL','PT','RO','SE','SI','SK')\n  AND RE.dErstellt >= DATEFROMPARTS(:year, :month, 1)\n  AND RE.dErstellt <  DATEADD(MONTH, 1, DATEFROMPARTS(:year, :month, 1))\nGROUP BY A.cTaric, RE.cVersandlandISO, RELI.cISO, REPO.cEinheit\n",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "position_number",
            "commodity_code",
            "country_of_origin",
            "partner_country",
            "transaction_nature",
            "mode_of_transport",
            "net_mass",
            "statistical_value",
            "invoiced_amount",
            "quantity_unit"
          ],
          "width": 350,
          "height": 244
        }
      ],
