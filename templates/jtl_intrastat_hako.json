    {
      "id": "mapping_22",
      "name": "Intrastat Einfuhr (eSTATISTIK.core)",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 111,
          "y": 28,
          "connection_id": "{{connection_10}}",
          "sql": "SELECT\n    ROW_NUMBER() OVER (ORDER BY A.cTaric, E.cLandISO) AS position_number,\n    A.cTaric AS commodity_code,\n    E.cLandISO AS country_of_origin,\n    E.cLandISO AS versendungsland,\n    'DE' AS partner_country,\n    '11' AS transaction_nature,\n    '3' AS mode_of_transport,\n    CAST(ROUND(SUM(EP.fMenge * A.fGewicht), 0) AS INT) AS net_mass,\n    CAST(ROUND(SUM(EP.fMenge * EP.fEKNetto), 0) AS INT) AS statistical_value,\n    CAST(ROUND(SUM(EP.fMenge * EP.fEKNetto), 0) AS INT) AS invoiced_amount,\n    '' AS quantity_unit\nFROM dbo.tEingangsrechnung E\nJOIN dbo.tEingangsrechnungPos EP ON EP.kEingangsrechnung = E.kEingangsrechnung\nJOIN dbo.tArtikel A ON A.kArtikel = EP.kArtikel\nWHERE E.cLandISO IN ('AT','BE','BG','HR','CY','CZ','DK','EE','ES','FI','FR','GR','HU','IE','IT','LT','LU','LV','MT','NL','PL','PT','RO','SE','SI','SK')\n  AND E.dErstellt >= DATEFROMPARTS(:year, :month, 1)\n  AND E.dErstellt <  DATEADD(MONTH, 1, DATEFROMPARTS(:year, :month, 1))\nGROUP BY A.cTaric, E.cLandISO\n",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "position_number",
            "commodity_code",
            "country_of_origin",
            "versendungsland",
            "partner_country",
            "transaction_nature",
            "mode_of_transport",
            "net_mass",
            "statistical_value",
            "invoiced_amount",
            "quantity_unit"
          ],
          "width": 350,
