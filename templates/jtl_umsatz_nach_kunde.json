      "targets": [
        {
          "id": "t1",
          "name": "Umsatz nach Land",
          "target_type": "dataset",
          "target_connection_id": null,
          "target_table": "",
          "target_write_mode": "replace",
          "target_options": {},
          "fields": [
            {
              "source_field": "Land",
              "target_field": "Land",
              "target_type": "string",
              "source_dataset_id": "__sql__sql1",
              "transformer": {
                "type": "direct",
                "source_field": "Land"
              }
            },
            {
              "source_field": "Umsatz",
              "target_field": "Umsatz",
              "target_type": "float",
              "source_dataset_id": "__sql__sql1",
              "transformer": {
                "type": "direct",
                "source_field": "Umsatz"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mapping_tabelle",
      "name": "Kundenliste (Detail)",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "SELECT TOP 100\n    ISNULL(NULLIF(LTRIM(RTRIM(RE.cFirma)), ''), LTRIM(RTRIM(ISNULL(RE.cVorname, '') + ' ' + ISNULL(RE.cName, '')))) AS Kunde,\n    RE.cOrt AS Ort,\n    RE.cLandISO AS Land,\n    COUNT(DISTINCT RE.cRechnungsNr) AS Rechnungen,\n    CAST(SUM(REPO.fAnzahl * REPO.fVkNetto) AS DECIMAL(18,2)) AS Umsatz\nFROM Rechnung.vRechnung RE\nJOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\nWHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n  AND RE.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))\nGROUP BY RE.cFirma, RE.cVorname, RE.cName, RE.cOrt, RE.cLandISO\nORDER BY Umsatz DESC",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Kunde",
            "Ort",
            "Land",
            "Rechnungen",
            "Umsatz"
          ]
        }
      ],
