    {
      "id": "mapping_einkauf_lieferant",
      "name": "Einkauf nach Lieferant",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "SELECT TOP 15\n    ISNULL(L.cFirma, '(ohne Lieferant)') AS Lieferant,\n    CAST(SUM(EP.fMenge * EP.fEKNetto) AS DECIMAL(18,2)) AS Einkaufswert\nFROM dbo.tEingangsrechnung E\nJOIN dbo.tEingangsrechnungPos EP ON EP.kEingangsrechnung = E.kEingangsrechnung\nLEFT JOIN dbo.tLieferant L ON L.kLieferant = E.kLieferant\nLEFT JOIN dbo.tArtikel A ON A.kArtikel = EP.kArtikel\nWHERE E.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))\nGROUP BY ISNULL(L.cFirma, '(ohne Lieferant)')\nORDER BY Einkaufswert DESC",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Lieferant",
            "Einkaufswert"
          ]
        }
