          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "WITH letzter_verkauf AS (\n    SELECT REPO.cArtNr AS Artikelnummer, MAX(RE.dErstellt) AS Letzter_Verkauf\n    FROM Rechnung.vRechnung RE\n    JOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\n    WHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n    GROUP BY REPO.cArtNr\n)\nSELECT TOP 100\n    A.cArtNr AS Artikelnummer,\n    ISNULL(AB.cName, '') AS Artikelname,\n    LB.fLagerbestand AS Bestand,\n    CAST(LB.fLagerbestand * A.fEKNetto AS DECIMAL(18,2)) AS Bestandswert,\n    LV.Letzter_Verkauf AS Letzter_Verkauf,\n    DATEDIFF(DAY, LV.Letzter_Verkauf, GETDATE()) AS Tage_ohne_Verkauf\nFROM dbo.tArtikel A\nJOIN dbo.tlagerbestand LB ON LB.kArtikel = A.kArtikel\nLEFT JOIN dbo.tArtikelBeschreibung AB ON AB.kArtikel = A.kArtikel AND AB.kSprache = 1 AND AB.kPlattform = 1\nLEFT JOIN letzter_verkauf LV ON LV.Artikelnummer = A.cArtNr\nWHERE LB.fLagerbestand > 0\n  AND (LV.Letzter_Verkauf IS NULL OR LV.Letzter_Verkauf < DATEADD(DAY, -{{ladenhueter_tage}}, GETDATE()))\nORDER BY Bestandswert DESC",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Artikelnummer",
            "Artikelname",
            "Bestand",
            "Bestandswert",
            "Letzter_Verkauf",
            "Tage_ohne_Verkauf"
          ]
        }
      ],
