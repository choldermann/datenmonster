      "id": "mapping_kpi_umsatz",
      "name": "KPI Umsatz",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "SELECT CAST(SUM(REPO.fAnzahl * REPO.fVkNetto) AS DECIMAL(18,2)) AS Umsatz\nFROM Rechnung.vRechnung RE\nJOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\nWHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n  AND RE.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Umsatz"
          ]
        }
      ],
