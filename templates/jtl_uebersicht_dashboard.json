    {
      "id": "mapping_abc_verteilung",
      "name": "ABC-Verteilung",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "WITH au AS (\n    SELECT REPO.cArtNr AS Artikelnummer, SUM(REPO.fAnzahl * REPO.fVkNetto) AS Umsatz\n    FROM Rechnung.vRechnung RE\n    JOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\n    WHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n      AND RE.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))\n    GROUP BY REPO.cArtNr\n),\nranked AS (\n    SELECT Umsatz, SUM(Umsatz) OVER () AS Gesamt,\n           SUM(Umsatz) OVER (ORDER BY Umsatz DESC ROWS UNBOUNDED PRECEDING) AS Kumuliert\n    FROM au\n)\nSELECT CASE WHEN Kumuliert / NULLIF(Gesamt, 0) <= 0.80 THEN 'A' WHEN Kumuliert / NULLIF(Gesamt, 0) <= 0.95 THEN 'B' ELSE 'C' END AS ABC_Klasse, CAST(SUM(Umsatz) AS DECIMAL(18,2)) AS Umsatz\nFROM ranked\nGROUP BY CASE WHEN Kumuliert / NULLIF(Gesamt, 0) <= 0.80 THEN 'A' WHEN Kumuliert / NULLIF(Gesamt, 0) <= 0.95 THEN 'B' ELSE 'C' END\nORDER BY ABC_Klasse",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "ABC_Klasse",
            "Umsatz"
          ]
        }
      ],
      "agg_nodes": [],
      "transform_nodes": [],
      "constant_nodes": [],
      "rest_nodes": [],
      "lookup_nodes": [],
      "calc_nodes": [],
      "switch_nodes": [],
      "sort_nodes": [],
      "targets": [
        {
          "id": "t1",
          "name": "ABC-Verteilung",
