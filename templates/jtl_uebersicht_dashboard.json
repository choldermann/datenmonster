          "connection_id": "{{connection_jtl}}",
          "sql": "SELECT CAST(SUM(EP.fMenge * EP.fEKNetto) AS DECIMAL(18,2)) AS Einkauf\nFROM dbo.tEingangsrechnung E\nJOIN dbo.tEingangsrechnungPos EP ON EP.kEingangsrechnung = E.kEingangsrechnung\nLEFT JOIN dbo.tLieferant L ON L.kLieferant = E.kLieferant\nLEFT JOIN dbo.tArtikel A ON A.kArtikel = EP.kArtikel\nWHERE E.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))",
          "mode": "transform",
