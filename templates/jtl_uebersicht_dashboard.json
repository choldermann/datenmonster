    {
      "id": "mapping_abc_detail",
      "name": "ABC-Analyse (Detail)",
      "canvas_nodes": [],
      "joins": [],
      "sql_nodes": [
        {
          "id": "sql1",
          "x": 120,
          "y": 40,
          "width": 350,
          "height": 244,
          "connection_id": "{{connection_jtl}}",
          "sql": "WITH artikel_umsatz AS (\n    SELECT REPO.cArtNr AS Artikelnummer, MAX(REPO.cName) AS Artikelname,\n           SUM(REPO.fAnzahl * REPO.fVkNetto) AS Umsatz\n    FROM Rechnung.vRechnung RE\n    JOIN Rechnung.tRechnungPosition REPO ON RE.kRechnung = REPO.kRechnung\n    WHERE REPO.cArtNr IS NOT NULL AND REPO.cArtNr <> ''\n      AND RE.dErstellt >= DATEADD(MONTH, -{{monate}}, CAST(GETDATE() AS date))\n    GROUP BY REPO.cArtNr\n),\nranked AS (\n    SELECT Artikelnummer, Artikelname, Umsatz,\n           SUM(Umsatz) OVER () AS Gesamt,\n           SUM(Umsatz) OVER (ORDER BY Umsatz DESC ROWS UNBOUNDED PRECEDING) AS Kumuliert\n    FROM artikel_umsatz\n)\nSELECT TOP 100 Artikelnummer, Artikelname,\n       CAST(Umsatz AS DECIMAL(18,2)) AS Umsatz,\n       CAST(100.0 * Kumuliert / NULLIF(Gesamt, 0) AS DECIMAL(5,1)) AS Kumuliert_Prozent,\n       CASE WHEN Kumuliert / NULLIF(Gesamt, 0) <= 0.80 THEN 'A' WHEN Kumuliert / NULLIF(Gesamt, 0) <= 0.95 THEN 'B' ELSE 'C' END AS ABC_Klasse\nFROM ranked\nORDER BY Umsatz DESC",
          "mode": "transform",
          "output_field": "sql_1",
          "output_fields": [
            "Artikelnummer",
            "Artikelname",
            "Umsatz",
            "Kumuliert_Prozent",
            "ABC_Klasse"
          ]
        }
      ],
